{
  "name": "@weysabi/server",
  "version": "0.9.0",
  "description": "OpenAI-compatible HTTP server for @weysabi/sabi",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "bin": {
    "weysabi-server": "./src/cli.ts"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "files": [
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "bun build ./src/index.ts --outdir ./dist --target bun --format esm",
    "dev": "bun --watch ./src/index.ts",
    "format": "bunx prettier --write .",
    "typecheck": "bunx tsc --noEmit",
    "test": "bun test"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/weysabi/sabi.git"
  },
  "engines": {
    "bun": ">=1.3.1"
  },
  "dependencies": {
    "@joinremba/beacon": "^0.5.2",
    "@joinremba/catalog": "^0.5.0",
    "@joinremba/gate": "^0.5.3",
    "@weysabi/sabi": "^0.9.0",
    "hono": "^4.12.26",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3"
  }
}
