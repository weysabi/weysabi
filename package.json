{
  "name": "@weysabi/sabi",
  "version": "0.5.0",
  "description": "AI orchestration for fullstack devs — provider failover, structured output, RAG, and streaming. One library, zero markup.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./errors": {
      "types": "./src/errors.ts",
      "import": "./src/errors.ts",
      "default": "./src/errors.ts"
    },
    "./hono": {
      "types": "./src/hono.ts",
      "import": "./src/hono.ts",
      "default": "./src/hono.ts"
    },
    "./next": {
      "types": "./src/next.ts",
      "import": "./src/next.ts",
      "default": "./src/next.ts"
    },
    "./express": {
      "types": "./src/express.ts",
      "import": "./src/express.ts",
      "default": "./src/express.ts"
    },
    "./fastify": {
      "types": "./src/fastify.ts",
      "import": "./src/fastify.ts",
      "default": "./src/fastify.ts"
    },
    "./elysia": {
      "types": "./src/elysia.ts",
      "import": "./src/elysia.ts",
      "default": "./src/elysia.ts"
    },
    "./sse": {
      "types": "./src/sse.ts",
      "import": "./src/sse.ts",
      "default": "./src/sse.ts"
    }
  },
  "files": [
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "bun build ./src/index.ts --outdir ./dist --target bun --format esm",
    "dev": "bun --watch ./src/index.ts",
    "format": "bunx prettier --write .",
    "format:check": "bunx prettier --check .",
    "lint": "bunx eslint .",
    "lint:fix": "bunx eslint . --fix",
    "typecheck": "bunx tsc --noEmit",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "prepublishOnly": "bun run build",
    "check": "bun run lint; bun run format:check; bun run typecheck; bun run test"
  },
  "author": {
    "name": "Benson Isaac",
    "email": "bensxnisaac@gmail.com"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/weysabi/sabi.git"
  },
  "bugs": {
    "url": "https://github.com/weysabi/sabi/issues"
  },
  "homepage": "https://github.com/weysabi/sabi#readme",
  "keywords": [
    "ai",
    "llm",
    "orchestrator",
    "failover",
    "circuit-breaker",
    "prompt",
    "template",
    "groq",
    "openai",
    "anthropic"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "bun": ">=1.3.1"
  },
  "dependencies": {
    "@joinremba/catalog": "^0.5.0",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3"
  }
}
