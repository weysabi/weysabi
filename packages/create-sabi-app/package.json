  },
  "engines": {
    "bun": ">=1.3.1"
  },
  "dependencies": {
    "@weysabi/sabi": "^0.10.0",
    "commander": "^15.0.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5"
