{
  "name": "create-sabi-app",
  "version": "0.10.0",
  "description": "Scaffold a new Sabi AI application",
  "type": "module",
  "bin": {
    "create-sabi-app": "./src/index.ts"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "files": [
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "typecheck": "bunx tsc --noEmit"
  },
